# 服务端口（可选，默认 3000）
PORT=3000

# ── 阿里云 RDS MySQL（生产必须启用）──
# USE_DATABASE=true 时：API 只读 MySQL，ESPN 由下方定时任务写入
USE_DATABASE=true
DB_HOST=rm-xxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=zuqiu
DB_PASSWORD=your_password
DB_NAME=zuqiu

# ── 定时同步（USE_DATABASE=true 时生效）──
SYNC_ENABLED=true
SYNC_SCHEDULE_MS=300000
SYNC_LIVE_MS=45000
SYNC_STANDINGS_MS=21600000
SYNC_PLAYER_STATS_MS=21600000
SYNC_TEAMS_MS=86400000
# ESPN 代理模式下后台预热缓存间隔（毫秒）
WARMUP_INTERVAL_MS=180000
# 已结束比赛保留天数（超出后从 matches 表清理）
SYNC_MATCH_RETENTION_DAYS=90
