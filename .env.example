# 服务端口（可选，默认 3000）
PORT=3000

# ── 阿里云 RDS MySQL（生产必须启用）──
# USE_DATABASE=true 时：API 只读 MySQL，ESPN 由下方定时任务写入
USE_DATABASE=true
DB_HOST=rm-xxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=zuqiu
DB_PASSWORD=your_password
DB_NAME=zuqiu

# ── 定时同步（USE_DATABASE=true 时生效）──
SYNC_ENABLED=true
SYNC_SCHEDULE_MS=300000
SYNC_LIVE_MS=45000
SYNC_STANDINGS_MS=21600000
SYNC_PLAYER_STATS_MS=21600000
SYNC_TEAMS_MS=86400000
# ESPN 代理模式下后台预热缓存间隔（毫秒）
WARMUP_INTERVAL_MS=180000
# 已结束比赛保留天数（超出后从 matches 表清理）
SYNC_MATCH_RETENTION_DAYS=90

# ── 微信小程序（比赛提醒）──
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
# 订阅消息模板 ID（公众平台「比赛开始提醒」，填好后重启服务）
REMINDER_TEMPLATE_ID=
# 发送扫描间隔（毫秒，默认 5 分钟）
REMINDER_SEND_MS=300000
# 登录 token 有效期（天）
AUTH_TOKEN_DAYS=30
# 订阅消息跳转版本：developer / trial / formal
WECHAT_MINIPROGRAM_STATE=formal
# 「比赛开始提醒」模板字段名（默认 thing6/thing2/thing3/thing5，与公众平台一致时可不改）
# REMINDER_TMPL_FIELD_MATCHUP=thing6
# REMINDER_TMPL_FIELD_TIME=thing2
# REMINDER_TMPL_FIELD_LEAGUE=thing3
# REMINDER_TMPL_FIELD_TIP=thing5
# 发送记录保留天数
REMINDER_LOG_RETENTION_DAYS=30
